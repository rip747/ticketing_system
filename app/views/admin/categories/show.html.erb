<% content_for :page_title, @category.name %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h5 class="fw-bold mb-0" style="color:#2d3748;">
    <i class="bi bi-tag me-2"></i><%= @category.name %>
  </h5>
  <div class="d-flex gap-2">
    <%= link_to edit_admin_category_path(@category), class: "btn btn-outline-primary btn-sm" do %>
      <i class="bi bi-pencil me-1"></i> Edit
    <% end %>
    <%= link_to admin_categories_path, class: "btn btn-outline-secondary btn-sm" do %>
      <i class="bi bi-arrow-left me-1"></i> Back
    <% end %>
  </div>
</div>

<div class="card-custom">
  <div class="card-body">
    <div class="mb-3">
      <strong style="color:#718096;font-size:0.85rem;">Department</strong>
      <p class="mb-0 mt-1"><%= @category.department.name %></p>
    </div>
    <div class="mb-3">
      <strong style="color:#718096;font-size:0.85rem;">Description</strong>
      <p class="mb-0 mt-1"><%= @category.description.presence || "No description provided." %></p>
    </div>
    <div class="row g-3">
      <div class="col-md-4">
        <div class="p-3" style="background:#f7fafc;border-radius:10px;">
          <strong style="color:#718096;font-size:0.85rem;">Tickets</strong>
          <p class="mb-0 mt-1 fs-5 fw-bold"><%= @category.tickets.count %></p>
        </div>
      </div>
    </div>
  </div>
</div>
