<% content_for :page_title, "Admin Dashboard" %>

<div class="row g-3 mb-4">
  <div class="col-xl-3 col-md-6">
    <div class="stat-card d-flex align-items-center gap-3">
      <div class="stat-icon" style="background:#ebf4ff;color:#3182ce;"><i class="bi bi-people-fill"></i></div>
      <div>
        <div class="stat-value"><%= @total_users %></div>
        <div class="stat-label">Total Users</div>
      </div>
    </div>
  </div>
  <div class="col-xl-3 col-md-6">
    <div class="stat-card d-flex align-items-center gap-3">
      <div class="stat-icon" style="background:#e6fffa;color:#38a169;"><i class="bi bi-ticket-perforated-fill"></i></div>
      <div>
        <div class="stat-value"><%= @total_tickets %></div>
        <div class="stat-label">Total Tickets</div>
      </div>
    </div>
  </div>
  <div class="col-xl-3 col-md-6">
    <div class="stat-card d-flex align-items-center gap-3">
      <div class="stat-icon" style="background:#fefcbf;color:#d69e2e;"><i class="bi bi-clock"></i></div>
      <div>
        <div class="stat-value"><%= @open_tickets %></div>
        <div class="stat-label">Open Tickets</div>
      </div>
    </div>
  </div>
  <div class="col-xl-3 col-md-6">
    <div class="stat-card d-flex align-items-center gap-3">
      <div class="stat-icon" style="background:#f0f0f0;color:#718096;"><i class="bi bi-check-all"></i></div>
      <div>
        <div class="stat-value"><%= @resolved_tickets %></div>
        <div class="stat-label">Resolved</div>
      </div>
    </div>
  </div>
</div>

<div class="row g-3">
  <div class="col-md-6">
    <div class="card-custom">
      <div class="card-header">Recent Tickets</div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-custom">
            <thead><tr><th>#</th><th>Subject</th><th>Status</th><th>User</th></tr></thead>
            <tbody>
              <% @recent_tickets.each do |t| %>
                <tr>
                  <td><%= link_to "##{t.id}", t, style: "color:var(--primary-color);text-decoration:none;" %></td>
                  <td><%= truncate(t.subject, length: 40) %></td>
                  <td><span class="badge-status badge-<%= t.status %>"><%= t.status.titleize %></span></td>
                  <td style="font-size:0.85rem;"><%= t.user.name %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card-custom">
      <div class="card-header">Recent Users</div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-custom">
            <thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Joined</th></tr></thead>
            <tbody>
              <% @recent_users.each do |u| %>
                <tr>
                  <td><%= u.name %></td>
                  <td style="font-size:0.85rem;"><%= u.email %></td>
                  <td><span class="badge bg-light text-dark text-capitalize"><%= u.role %></span></td>
                  <td style="font-size:0.85rem;color:#718096;"><%= time_ago_in_words(u.created_at) %> ago</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
