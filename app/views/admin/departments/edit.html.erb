<h5 class="fw-bold mb-3" style="color:#2d3748;"><i class="bi bi-pencil me-2"></i>Edit Department</h5>

<div class="row justify-content-center">
  <div class="col-lg-6">
    <div class="card-custom">
      <div class="card-body">
        <%= form_with model: [:admin, @department], class: "needs-validation" do |f| %>
          <% if @department.errors.any? %>
            <div class="alert alert-danger" style="border-radius:10px;border:none;"><%= @department.errors.full_messages.to_sentence %></div>
          <% end %>
          <div class="mb-3">
            <%= f.label :name, class: "form-label fw-medium" %>
            <%= f.text_field :name, class: "form-control", required: true %>
          </div>
          <div class="mb-4">
            <%= f.label :description, class: "form-label fw-medium" %>
            <%= f.text_area :description, class: "form-control", rows: 3 %>
          </div>
          <div class="d-flex gap-2">
            <%= f.submit "Update Department", class: "btn btn-primary" %>
            <%= link_to "Cancel", admin_departments_path, class: "btn btn-outline-secondary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>