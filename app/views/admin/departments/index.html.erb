<% content_for :page_title, "Departments" %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h5 class="fw-bold mb-0" style="color:#2d3748;"><i class="bi bi-building me-2"></i>Departments</h5>
  <%= link_to new_admin_department_path, class: "btn btn-primary btn-sm" do %>
    <i class="bi bi-plus-lg me-1"></i> New Department
  <% end %>
</div>

<div class="card-custom">
  <div class="card-body p-0">
    <% if @departments.any? %>
      <div class="table-responsive">
        <table class="table table-custom">
          <thead>
            <tr><th>Name</th><th>Description</th><th>Categories</th><th>Agents</th><th>Tickets</th><th></th></tr>
          </thead>
          <tbody>
            <% @departments.each do |dept| %>
              <tr>
                <td data-label="Name" class="fw-medium"><%= dept.name %></td>
                <td data-label="Description" style="font-size:0.85rem;color:#718096;"><%= truncate(dept.description, length: 50) %></td>
                <td data-label="Categories"><span class="badge bg-light text-dark"><%= dept.categories.count %></span></td>
                <td data-label="Agents"><span class="badge bg-light text-dark"><%= dept.users.count %></span></td>
                <td data-label="Tickets"><span class="badge bg-light text-dark"><%= dept.tickets.count %></span></td>
                <td data-label="">
                  <div class="dropdown">
                    <button class="btn btn-sm btn-light" data-bs-toggle="dropdown"><i class="bi bi-three-dots-vertical"></i></button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="border-radius:10px;border:none;">
                      <li><%= link_to edit_admin_department_path(dept), class: "dropdown-item" do %><i class="bi bi-pencil me-2"></i> Edit<% end %></li>
                      <li><hr class="dropdown-divider"></li>
                      <li><%= button_to admin_department_path(dept), method: :delete, class: "dropdown-item text-danger", form: { data: { turbo_confirm: "Delete '#{dept.name}'? This will also remove its categories." } } do %><i class="bi bi-trash me-2"></i> Delete<% end %></li>
                    </ul>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-5" style="color:#718096;">
        <i class="bi bi-building" style="font-size:2rem;display:block;margin-bottom:12px;"></i>
        <p>No departments created yet.</p>
        <%= link_to "Create Department", new_admin_department_path, class: "btn btn-primary btn-sm" %>
      </div>
    <% end %>
  </div>
</div>