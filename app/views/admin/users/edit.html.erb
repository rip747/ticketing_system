<h5 class="fw-bold mb-3" style="color:#2d3748;"><i class="bi bi-pencil me-2"></i>Edit User</h5>

<div class="row justify-content-center">
  <div class="col-lg-6">
    <div class="card-custom">
      <div class="card-body">
        <%= form_with model: [:admin, @user], class: "needs-validation" do |f| %>
          <% if @user.errors.any? %>
            <div class="alert alert-danger" style="border-radius:10px;border:none;"><%= @user.errors.full_messages.to_sentence %></div>
          <% end %>
          <div class="mb-3">
            <%= f.label :name, "Full Name", class: "form-label fw-medium" %>
            <%= f.text_field :name, class: "form-control", required: true %>
          </div>
          <div class="mb-3">
            <%= f.label :email, class: "form-label fw-medium" %>
            <%= f.email_field :email, class: "form-control", required: true %>
          </div>
          <div class="mb-3">
            <%= f.label :role, class: "form-label fw-medium" %>
            <%= f.select :role, options_for_select([["Customer", "customer"], ["Agent", "agent"], ["Admin", "admin"]], @user.role), {}, class: "form-select" %>
          </div>
          <div class="mb-3">
            <%= f.label :department_id, "Department", class: "form-label fw-medium" %>
            <%= f.collection_select :department_id, Department.all, :id, :name, { prompt: "No department" }, class: "form-select" %>
          </div>
          <hr>
          <p class="text-muted small">Leave password blank to keep current</p>
          <div class="mb-3">
            <%= f.label :password, class: "form-label fw-medium" %>
            <%= f.password_field :password, class: "form-control", placeholder: "Leave blank to keep current" %>
          </div>
          <div class="mb-4">
            <%= f.label :password_confirmation, "Confirm Password", class: "form-label fw-medium" %>
            <%= f.password_field :password_confirmation, class: "form-control", placeholder: "Confirm if changing" %>
          </div>
          <div class="d-flex gap-2">
            <%= f.submit "Update User", class: "btn btn-primary" %>
            <%= link_to "Cancel", admin_users_path, class: "btn btn-outline-secondary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>