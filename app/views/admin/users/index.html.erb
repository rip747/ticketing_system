<% content_for :page_title, "Users" %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h5 class="fw-bold mb-0" style="color:#2d3748;"><i class="bi bi-people-fill me-2"></i>Users</h5>
  <%= link_to new_admin_user_path, class: "btn btn-primary btn-sm" do %>
    <i class="bi bi-plus-lg me-1"></i> New User
  <% end %>
</div>

<!-- Filter -->
<div class="filter-bar">
  <%= form_tag admin_users_path, method: :get, class: "row g-2 align-items-end" do %>
    <div class="col-auto">
      <%= select_tag :role, options_for_select([["All Roles", ""], ["Admin", "admin"], ["Agent", "agent"], ["Customer", "customer"]], params[:role]), class: "form-select form-select-sm" %>
    </div>
    <div class="col-auto">
      <%= submit_tag "Filter", class: "btn btn-primary btn-sm" %>
    </div>
  <% end %>
</div>

<div class="card-custom">
  <div class="card-body p-0">
    <% if @users.any? %>
      <div class="table-responsive">
        <table class="table table-custom">
          <thead>
            <tr><th>Name</th><th>Email</th><th>Role</th><th>Department</th><th>Tickets</th><th>Joined</th><th></th></tr>
          </thead>
          <tbody>
            <% @users.each do |user| %>
              <tr>
                <td data-label="Name">
                  <div class="d-flex align-items-center gap-2">
                    <div style="width:32px;height:32px;border-radius:50%;background:var(--primary-color);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:600;font-size:0.8rem;">
                      <%= user.name.to_s[0]&.upcase || "?" %>
                    </div>
                    <span class="fw-medium"><%= user.name %></span>
                  </div>
                </td>
                <td data-label="Email" style="font-size:0.85rem;"><%= user.email %></td>
                <td data-label="Role"><span class="badge bg-light text-dark text-capitalize"><%= user.role %></span></td>
                <td data-label="Department" style="font-size:0.85rem;"><%= user.department&.name || "—" %></td>
                <td data-label="Tickets"><span class="badge bg-light text-dark"><%= user.tickets.count %></span></td>
                <td data-label="Joined" style="font-size:0.85rem;color:#718096;"><%= time_ago_in_words(user.created_at) %> ago</td>
                <td data-label="">
                  <div class="dropdown">
                    <button class="btn btn-sm btn-light" data-bs-toggle="dropdown"><i class="bi bi-three-dots-vertical"></i></button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="border-radius:10px;border:none;">
                      <li><%= link_to edit_admin_user_path(user), class: "dropdown-item" do %><i class="bi bi-pencil me-2"></i> Edit<% end %></li>
                      <li><hr class="dropdown-divider"></li>
                      <li><%= button_to admin_user_path(user), method: :delete, class: "dropdown-item text-danger", form: { data: { turbo_confirm: "Delete '#{user.name}'?" } } do %><i class="bi bi-trash me-2"></i> Delete<% end %></li>
                    </ul>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-5" style="color:#718096;">
        <i class="bi bi-people" style="font-size:2rem;display:block;margin-bottom:12px;"></i>
        <p>No users found.</p>
      </div>
    <% end %>
  </div>
</div>