<% content_for :page_title, @user.name %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h5 class="fw-bold mb-0" style="color:#2d3748;">
    <i class="bi bi-person me-2"></i><%= @user.name %>
  </h5>
  <div class="d-flex gap-2">
    <%= link_to edit_admin_user_path(@user), class: "btn btn-outline-primary btn-sm" do %>
      <i class="bi bi-pencil me-1"></i> Edit
    <% end %>
    <%= link_to admin_users_path, class: "btn btn-outline-secondary btn-sm" do %>
      <i class="bi bi-arrow-left me-1"></i> Back
    <% end %>
  </div>
</div>

<div class="card-custom">
  <div class="card-body">
    <div class="row mb-3">
      <div class="col-md-6">
        <strong style="color:#718096;font-size:0.85rem;">Email</strong>
        <p class="mb-0 mt-1"><%= @user.email %></p>
      </div>
      <div class="col-md-6">
        <strong style="color:#718096;font-size:0.85rem;">Role</strong>
        <p class="mb-0 mt-1"><span class="badge <%= @user.admin? ? 'bg-danger' : (@user.agent_or_admin? ? 'bg-info' : 'bg-secondary') %>"><%= @user.role.titleize %></span></p>
      </div>
    </div>
    <div class="mb-3">
      <strong style="color:#718096;font-size:0.85rem;">Department</strong>
      <p class="mb-0 mt-1"><%= @user.department&.name || "Not assigned" %></p>
    </div>
    <div class="row g-3">
      <div class="col-md-4">
        <div class="p-3" style="background:#f7fafc;border-radius:10px;">
          <strong style="color:#718096;font-size:0.85rem;">Tickets Created</strong>
          <p class="mb-0 mt-1 fs-5 fw-bold"><%= @user.tickets.count %></p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="p-3" style="background:#f7fafc;border-radius:10px;">
          <strong style="color:#718096;font-size:0.85rem;">Assigned Tickets</strong>
          <p class="mb-0 mt-1 fs-5 fw-bold"><%= @user.assigned_tickets.count %></p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="p-3" style="background:#f7fafc;border-radius:10px;">
          <strong style="color:#718096;font-size:0.85rem;">Comments</strong>
          <p class="mb-0 mt-1 fs-5 fw-bold"><%= @user.comments.count %></p>
        </div>
      </div>
    </div>
  </div>
</div>
