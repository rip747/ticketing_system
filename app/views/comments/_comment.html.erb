<div class="comment-bubble" id="<%= dom_id(comment) %>">
  <div class="d-flex justify-content-between align-items-start">
    <div class="d-flex align-items-center gap-2 mb-2">
      <div style="width:32px;height:32px;border-radius:50%;background:#e2e8f0;display:flex;align-items:center;justify-content:center;font-weight:600;font-size:0.8rem;color:#4a5568;">
        <%= comment.user.name.to_s[0]&.upcase || "?" %>
      </div>
      <div>
        <strong style="font-size:0.9rem;"><%= comment.user.name %></strong>
        <span class="comment-meta ms-2"><%= time_ago_in_words(comment.created_at) %> ago</span>
      </div>
    </div>
    <% if current_user.admin? || comment.user == current_user %>
      <%= button_to ticket_comment_path(comment.ticket, comment), method: :delete, class: "btn btn-sm btn-link text-danger p-0", form: { data: { turbo_confirm: "Delete this comment?" } } do %>
        <i class="bi bi-x"></i>
      <% end %>
    <% end %>
  </div>
  <p style="color:#4a5568;margin:0;white-space:pre-wrap;font-size:0.9rem;"><%= comment.body %></p>
</div>
