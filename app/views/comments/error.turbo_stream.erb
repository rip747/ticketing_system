<%= turbo_stream.update "comment_form" do %>
  <%= form_with model: [@ticket, @comment], class: "mt-3" do |f| %>
    <div class="alert alert-danger py-2 px-3 mb-2" style="border-radius:8px;font-size:0.85rem;">
      <i class="bi bi-exclamation-triangle-fill me-1"></i>
      <%= @comment.errors.full_messages.to_sentence %>
    </div>
    <div class="mb-2">
      <%= f.text_area :body, class: "form-control", rows: 3, placeholder: "Write a comment...", required: true %>
    </div>
    <%= f.submit "Add Comment", class: "btn btn-primary btn-sm" %>
  <% end %>
<% end %>
