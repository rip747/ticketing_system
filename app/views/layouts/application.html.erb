<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "HelpDesk - Ticketing System" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="HelpDesk">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </head>

  <body>
    <% if logged_in? %>
    <div data-controller="sidebar" class="sidebar-layout">
      <!-- Sidebar -->
      <div class="sidebar" id="sidebar" data-sidebar-target="drawer" data-action="click->sidebar#closeOnBackdrop">
        <div class="sidebar-brand">
          <i class="bi bi-ticket-perforated-fill"></i>
          <span>HelpDesk</span>
          <button class="sidebar-close" data-action="sidebar#close">
            <i class="bi bi-x-lg"></i>
          </button>
        </div>
        <nav class="sidebar-nav">
          <div class="nav-section">Main</div>
          <%= link_to root_path, class: "nav-item#{current_page?(root_path) ? ' active' : ''}" do %>
            <i class="bi bi-grid-1x2-fill"></i>
            <span class="nav-text" title="Dashboard">Dashboard</span>
          <% end %>
          <%= link_to tickets_path, class: "nav-item#{controller_name == 'tickets' ? ' active' : ''}" do %>
            <i class="bi bi-ticket-perforated"></i>
            <span class="nav-text" title="Tickets">Tickets</span>
            <% open_count = current_user.admin? ? Ticket.open.count : (current_user.agent_or_admin? ? Ticket.where(assigned_user_id: current_user.id).open.count : current_user.tickets.open.count) %>
            <% if open_count > 0 %>
              <span class="badge bg-danger rounded-pill"><%= open_count %></span>
            <% end %>
          <% end %>

          <% if current_user.agent_or_admin? %>
            <div class="nav-section mt-3">Management</div>
            <%= link_to admin_departments_path, class: "nav-item" do %>
              <i class="bi bi-building"></i>
              <span class="nav-text" title="Departments">Departments</span>
            <% end %>
            <%= link_to admin_categories_path, class: "nav-item" do %>
              <i class="bi bi-tags-fill"></i>
              <span class="nav-text">Categories</span>
            <% end %>
          <% end %>

          <% if current_user.admin? %>
            <div class="nav-section mt-3">Administration</div>
            <%= link_to admin_users_path, class: "nav-item" do %>
              <i class="bi bi-people-fill"></i>
              <span class="nav-text">Users</span>
            <% end %>
            <%= link_to admin_root_path, class: "nav-item" do %>
              <i class="bi bi-gear-fill"></i>
              <span class="nav-text">Settings</span>
            <% end %>
          <% end %>
        </nav>
        <button class="sidebar-collapse-toggle" data-action="sidebar#toggleCollapse" title="Toggle sidebar" hidden>
          <i class="bi bi-chevron-left" data-sidebar-target="collapseIcon"></i>
        </button>
      </div>

      <!-- Main Content -->
      <div class="main-content">
        <!-- Top Header -->
        <div class="top-header">
          <div class="d-flex align-items-center gap-3">
            <button class="sidebar-toggle" data-action="sidebar#toggle">
              <i class="bi bi-list"></i>
            </button>
            <span class="page-title"><%= content_for(:page_title) || controller_name.titleize %></span>
          </div>
          <div class="header-actions">
            <div class="dropdown">
              <div class="user-dropdown" data-bs-toggle="dropdown">
                <div class="user-avatar"><%= current_user.name.to_s[0]&.upcase || "?" %></div>
                <div>
                  <div style="font-size:0.85rem;font-weight:600;color:#2d3748;line-height:1.2;"><%= current_user.name.presence || "User" %></div>
                  <div style="font-size:0.7rem;color:#718096;text-transform:capitalize;"><%= current_user.role %></div>
                </div>
                <i class="bi bi-chevron-down ms-2" style="color:#718096;font-size:0.8rem;"></i>
              </div>
              <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="border-radius:10px;border:none;">
                <li><%= link_to profile_path, class: "dropdown-item" do %><i class="bi bi-person me-2"></i> My Profile<% end %></li>
                <li><%= link_to edit_profile_path, class: "dropdown-item" do %><i class="bi bi-pencil me-2"></i> Edit Profile<% end %></li>
                <li><hr class="dropdown-divider"></li>
                <li><%= link_to logout_path, class: "dropdown-item text-danger", data: { turbo_method: :delete } do %><i class="bi bi-box-arrow-right me-2"></i> Logout<% end %></li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Content -->
        <div class="content-area">
          <%= yield %>
        </div>
      </div>
    </div>
    <% else %>
      <!-- Public pages (login/register) -->
      <%= yield %>
    <% end %>

    <!-- Flash messages -->
    <div class="flash-container" data-controller="flash">
      <% flash.each do |type, message| %>
        <div class="alert alert-<%= type == 'notice' ? 'success' : 'danger' %> alert-dismissible fade show shadow-sm"
             role="alert"
             data-flash-target="item"
             data-action="mouseenter->flash#pause mouseleave->flash#resume">
          <div class="d-flex align-items-center gap-2">
            <i class="bi bi-<%= type == 'notice' ? 'check-circle-fill text-success' : 'exclamation-triangle-fill text-danger' %>"></i>
            <span><%= message %></span>
          </div>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>
    </div>
  </body>
</html>
