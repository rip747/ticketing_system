<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "System Admin - HelpDesk" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="HelpDesk">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </head>

  <body>
    <% if logged_in? && current_user&.sys_admin? %>
      <div class="system-layout">
        <!-- System Admin Top Bar -->
        <nav class="navbar navbar-dark bg-dark px-3" style="min-height:56px;">
          <div class="d-flex align-items-center gap-3">
            <span class="navbar-brand mb-0 h6">
              <i class="bi bi-shield-shaded me-2"></i>HelpDesk System
            </span>
            <%= link_to "Dashboard", system_root_path, class: "nav-link d-inline px-2 #{current_page?(system_root_path) ? 'active' : ''}" %>
            <%= link_to "Organizations", system_organizations_path, class: "nav-link d-inline px-2 #{controller_name == 'organizations' ? 'active' : ''}" %>
          </div>
          <div class="d-flex align-items-center gap-2">
            <span style="color:#adb5bd;font-size:0.8rem;">
              <i class="bi bi-person"></i> <%= current_user.name %>
            </span>
            <%= link_to "Back to App", system_root_path, class: "btn btn-outline-light btn-sm me-2" %>
            <%= link_to logout_path, class: "btn btn-outline-danger btn-sm", data: { turbo_method: :delete } do %>
              <i class="bi bi-box-arrow-right"></i> Logout
            <% end %>
          </div>
        </nav>

        <!-- Content -->
        <div class="container-fluid p-4">
          <%= yield %>
        </div>
      </div>

      <!-- Flash messages -->
      <div class="flash-container" data-controller="flash">
        <% flash.each do |type, message| %>
          <div class="alert alert-<%= type == 'notice' ? 'success' : 'danger' %> alert-dismissible fade show shadow-sm"
               role="alert"
               data-flash-target="item"
               data-action="mouseenter->flash#pause mouseleave->flash#resume">
            <div class="d-flex align-items-center gap-2">
              <i class="bi bi-<%= type == 'notice' ? 'check-circle-fill text-success' : 'exclamation-triangle-fill text-danger' %>"></i>
              <span><%= message %></span>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% end %>
      </div>
    <% else %>
      <!-- Login page (no session) -->
      <%= yield %>
    <% end %>
  </body>
</html>
