<% content_for :page_title, "New Organization" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="fw-bold mb-0" style="color:#1a1a2e;">New Organization</h4>
</div>

<div class="card border-0 shadow-sm" style="border-radius:12px;max-width:600px;">
  <div class="card-body p-4">
    <%= form_with model: @organization, url: system_organizations_path, local: true do |f| %>
      <% if @organization.errors.any? %>
        <div class="alert alert-danger">
          <%= @organization.errors.full_messages.to_sentence %>
        </div>
      <% end %>

      <div class="mb-3">
        <%= f.label :name, "Organization Name", class: "form-label fw-medium" %>
        <%= f.text_field :name, class: "form-control", placeholder: "e.g., Acme Corporation", required: true, autofocus: true %>
      </div>

      <div class="mb-4">
        <%= f.label :slug, "URL Slug (optional)", class: "form-label fw-medium" %>
        <%= f.text_field :slug, class: "form-control", placeholder: "auto-generated from name" %>
        <div class="form-text" style="font-size:0.8rem;color:#718096;">Leave blank to auto-generate from the organization name.</div>
      </div>

      <div class="d-flex gap-2">
        <%= f.submit "Create Organization", class: "btn btn-danger" %>
        <%= link_to "Cancel", system_organizations_path, class: "btn btn-outline-secondary" %>
      </div>
    <% end %>
  </div>
</div>
