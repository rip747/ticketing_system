<% content_for :page_title, @organization.name %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="fw-bold mb-1" style="color:#1a1a2e;"><%= @organization.name %></h4>
    <div style="color:#718096;font-size:0.85rem;">
      Slug: <code><%= @organization.slug %></code>
      &middot; Created <%= time_ago_in_words(@organization.created_at) %> ago
    </div>
  </div>
  <div>
    <%= link_to edit_system_organization_path(@organization), class: "btn btn-outline-secondary btn-sm me-1" do %>
      <i class="bi bi-pencil"></i> Edit
    <% end %>
    <%= link_to system_organizations_path, class: "btn btn-outline-danger btn-sm" do %>
      <i class="bi bi-arrow-left"></i> Back
    <% end %>
  </div>
</div>

<div class="row g-3">
  <!-- Users -->
  <div class="col-md-6">
    <div class="card border-0 shadow-sm" style="border-radius:12px;">
      <div class="card-header bg-transparent border-0 pt-3 pb-0 d-flex justify-content-between">
        <h6 class="fw-bold mb-0" style="color:#1a1a2e;">Users (<%= @users.count %>)</h6>
      </div>
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th class="ps-4">Name</th>
              <th>Email</th>
              <th>Role</th>
              <th class="pe-4">Department</th>
            </tr>
          </thead>
          <tbody>
            <% @users.each do |user| %>
              <tr>
                <td class="ps-4 fw-medium"><%= user.name %></td>
                <td style="color:#718096;"><%= user.email %></td>
                <td><span class="badge bg-<%= user.org_admin? ? 'danger' : (user.agent_or_admin? ? 'primary' : 'secondary') %>"><%= user.role %></span></td>
                <td class="pe-4"><%= user.department&.name || "—" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Departments -->
  <div class="col-md-3">
    <div class="card border-0 shadow-sm" style="border-radius:12px;">
      <div class="card-header bg-transparent border-0 pt-3 pb-0">
        <h6 class="fw-bold mb-0" style="color:#1a1a2e;">Departments</h6>
      </div>
      <div class="card-body">
        <% @departments.each do |dept| %>
          <div class="d-flex justify-content-between align-items-center py-1">
            <span><%= dept.name %></span>
            <span class="badge bg-light text-dark"><%= dept.users.count %> users</span>
          </div>
        <% end %>
        <% if @departments.empty? %>
          <div style="color:#718096;">No departments.</div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Recent Tickets -->
  <div class="col-md-3">
    <div class="card border-0 shadow-sm" style="border-radius:12px;">
      <div class="card-header bg-transparent border-0 pt-3 pb-0">
        <h6 class="fw-bold mb-0" style="color:#1a1a2e;">Recent Tickets</h6>
      </div>
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <tbody>
            <% @tickets.each do |ticket| %>
              <tr>
                <td class="ps-3">
                  <div class="fw-medium" style="font-size:0.85rem;"><%= truncate(ticket.subject, length: 40) %></div>
                  <div style="font-size:0.75rem;color:#718096;"><%= ticket.status %> &middot; <%= ticket.priority %></div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
