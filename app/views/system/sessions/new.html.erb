<div class="system-login-page">
  <div class="system-login-card">
    <div class="auth-logo">
      <i class="bi bi-shield-fill-exclamation"></i>
      <h3>System Administration</h3>
      <p>Secure panel for system administrators</p>
    </div>

    <%= form_tag system_login_path, class: "needs-validation" do %>
      <% if flash[:alert] %>
        <div class="alert alert-danger" style="border-radius:10px;border:none;">
          <i class="bi bi-exclamation-triangle-fill me-2"></i>
          <%= flash[:alert] %>
        </div>
      <% end %>

      <div class="mb-3">
        <%= label_tag :email, "Admin Email", class: "form-label fw-medium" %>
        <%= email_field_tag :email, nil, class: "form-control", placeholder: "admin@company.com", required: true, autofocus: true %>
      </div>

      <div class="mb-4">
        <%= label_tag :password, "Password", class: "form-label fw-medium" %>
        <%= password_field_tag :password, nil, class: "form-control", placeholder: "Enter your password", required: true %>
      </div>

      <%= submit_tag "Sign In to System Panel", class: "btn btn-danger w-100 py-2 fw-medium" %>
    <% end %>

    <div class="text-center mt-4">
      <%= link_to "← Back to regular login", login_path, style: "color:#718096;font-size:0.85rem;" %>
    </div>
  </div>
</div>
