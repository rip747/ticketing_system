<% content_for :page_title, "New Ticket" %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h5 class="fw-bold mb-0" style="color:#2d3748;"><i class="bi bi-plus-circle me-2"></i>Create New Ticket</h5>
  <%= link_to tickets_path, class: "btn btn-outline-secondary btn-sm" do %>
    <i class="bi bi-arrow-left me-1"></i> Back
  <% end %>
</div>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="card-custom">
      <div class="card-body">
        <%= form_with model: @ticket, class: "needs-validation" do |f| %>
          <% if @ticket.errors.any? %>
            <div class="alert alert-danger" style="border-radius:10px;border:none;">
              <%= @ticket.errors.full_messages.to_sentence %>
            </div>
          <% end %>

          <div class="mb-3">
            <%= f.label :subject, "Subject", class: "form-label fw-medium" %>
            <%= f.text_field :subject, class: "form-control", placeholder: "Brief summary of the issue", required: true, autofocus: true %>
          </div>

          <div class="mb-3">
            <%= f.label :description, "Description", class: "form-label fw-medium" %>
            <%= f.rich_textarea :description, class: "form-control", placeholder: "Detailed description of the issue... (supports rich text, images, and attachments)" %>
          </div>

          <div class="row g-3 mb-4">
            <div class="col-md-4">
              <%= f.label :department_id, "Department", class: "form-label fw-medium" %>
              <%= f.collection_select :department_id, Department.all, :id, :name, { prompt: "Select department" }, class: "form-select", required: true %>
            </div>
            <div class="col-md-4">
              <%= f.label :category_id, "Category", class: "form-label fw-medium" %>
              <%= f.grouped_collection_select :category_id, Department.all, :categories, :name, :id, :name, { prompt: "Select category" }, class: "form-select", required: true %>
            </div>
            <div class="col-md-4">
              <%= f.label :priority, "Priority", class: "form-label fw-medium" %>
              <%= f.select :priority, options_for_select([["Low", "low"], ["Medium", "medium"], ["High", "high"], ["Urgent", "urgent"]], "medium"), {}, class: "form-select" %>
            </div>
          </div>

          <div class="d-flex gap-2">
            <%= f.submit "Create Ticket", class: "btn btn-primary px-4" %>
            <%= link_to "Cancel", tickets_path, class: "btn btn-outline-secondary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
